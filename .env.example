# HomePlus Environment Variables
# Copy this file to .env and update the values

# ============================================
# DEMO MODE TOGGLE
# ============================================
# Set to "true" for demo/presentation mode with dummy data
# Set to "false" for production mode with real Supabase backend
VITE_DEMO_MODE="true"

# ============================================
# SUPABASE CONFIGURATION
# (Only used when VITE_DEMO_MODE is "false")
# ============================================
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ============================================
# DEMO CREDENTIALS (when VITE_DEMO_MODE="true")
# ============================================
# Email: demo@homeplus.com
# Password: demo123
#
# Note: In demo mode, any email/password combination will work.
# The above credentials are just for demonstration purposes.
